# Node.js依赖包（体积大，npm install会自动生成）
node_modules/

# npm缓存文件
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# 环境变量文件（如有）
.env
.env.local
.env.development.local
.env.test.local
.env.production.local

# 打包后的EXE文件（可选，如需分发可单独放release）
*.exe
dist/
build/

# IDE/编辑器配置文件
.idea/
.vscode/
*.swp
*.swo
.DS_Store

# 日志文件
logs/
*.log

# 临时文件
tmp/
temp/